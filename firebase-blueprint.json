{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with roles and permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "cashier", "pharmacy_staff", "e_center_operator"] },
        "branchId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Business branch location.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name"]
    },
    "Purchase": {
      "title": "Purchase Order",
      "description": "Stock purchase from suppliers.",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "dueAmount": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["supplierId", "totalAmount", "date"]
    },
    "Product": {
      "title": "Product/Medicine",
      "description": "Medicine or general store product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "genericName": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "salePrice": { "type": "number" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "isMedicine": { "type": "boolean" },
        "prescriptionRequired": { "type": "boolean" },
        "lowStockThreshold": { "type": "number" }
      },
      "required": ["name", "salePrice", "stock"]
    },
    "Batch": {
      "title": "Medicine Batch",
      "description": "Batch tracking for medicines with expiry dates.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "batchNumber": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "quantity": { "type": "number" }
      },
      "required": ["productId", "batchNumber", "expiryDate", "quantity"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information and due balance.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "dueBalance": { "type": "number" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale Transaction",
      "description": "POS sale record.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerMobile": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "subtotal": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "tax": { "type": "number" },
        "discount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "dueAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "bkash", "nagad", "card"] },
        "status": { "type": "string", "enum": ["completed", "held"] },
        "prescriptionNote": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "cashierId": { "type": "string" }
      },
      "required": ["totalAmount", "paidAmount", "createdAt", "status"]
    },
    "EService": {
      "title": "E-Service Billing",
      "description": "Billing for digital services like printing, scanning, etc.",
      "type": "object",
      "properties": {
        "serviceType": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "amount": { "type": "number" },
        "customerName": { "type": "string" },
        "customerMobile": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "operatorId": { "type": "string" },
        "remarks": { "type": "string" }
      },
      "required": ["serviceType", "amount", "createdAt", "quantity"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses.",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "recordedBy": { "type": "string" }
      },
      "required": ["category", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/branches/{branchId}": { "schema": "Branch", "description": "Branch locations" },
    "/products/{productId}": { "schema": "Product", "description": "Inventory items" },
    "/batches/{batchId}": { "schema": "Batch", "description": "Medicine batches" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer records" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Supplier records" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales transactions" },
    "/purchases/{purchaseId}": { "schema": "Purchase", "description": "Purchase records" },
    "/eservices/{serviceId}": { "schema": "EService", "description": "E-service records" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Business expenses" }
  }
}
